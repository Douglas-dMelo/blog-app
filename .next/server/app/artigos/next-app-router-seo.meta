{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/artigos/layout,_N_T_/artigos/[slug]/layout,_N_T_/artigos/[slug]/page,_N_T_/artigos/next-app-router-seo"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/artigos/$d$slug/__PAGE__",
    "/artigos/$d$slug",
    "/artigos",
    "/_index",
    "/_head"
  ]
}